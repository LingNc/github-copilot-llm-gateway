{
  "name": "github-copilot-llm-gateway",
  "displayName": "GitHub Copilot LLM Gateway",
  "description": "Connect GitHub Copilot to open-source models via vLLM or any OpenAI-compatible server",
  "version": "1.1.5",
  "publisher": "AndrewButson",
  "icon": "assets/copilot-llm-gateway.png",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arbs-io/github-copilot-llm-gateway.git"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/arbs-io"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=es2020",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test-compile": "tsc -p ./",
    "deploy": "vsce publish --no-yarn",
    "package": "vsce package --no-yarn"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "copilot",
    "vllm",
    "Ollama",
    "llama.cpp",
    "LocalAI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "llm-gateway",
        "displayName": "LLM Gateway"
      }
    ],
    "commands": [
      {
        "command": "github.copilot.llm-gateway.testConnection",
        "title": "%command.testConnection.title%",
        "category": "GitHub Copilot LLM Gateway"
      },
      {
        "command": "github.copilot.llm-gateway.openConfig",
        "title": "%command.openConfig.title%",
        "category": "GitHub Copilot LLM Gateway"
      },
      {
        "command": "github.copilot.llm-gateway.reloadConfig",
        "title": "%command.reloadConfig.title%",
        "category": "GitHub Copilot LLM Gateway"
      },
      {
        "command": "github.copilot.llm-gateway.addProvider",
        "title": "%command.addProvider.title%",
        "category": "GitHub Copilot LLM Gateway"
      },
      {
        "command": "github.copilot.llm-gateway.editProvider",
        "title": "%command.editProvider.title%",
        "category": "GitHub Copilot LLM Gateway"
      },
      {
        "command": "github.copilot.llm-gateway.removeProvider",
        "title": "%command.removeProvider.title%",
        "category": "GitHub Copilot LLM Gateway"
      },
      {
        "command": "github.copilot.llm-gateway.showTokenUsage",
        "title": "%command.showTokenUsage.title%",
        "category": "GitHub Copilot LLM Gateway",
        "icon": "$(graph)"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "llmGateway.tokenUsage",
          "name": "%view.tokenUsage.name%",
          "when": "github.copilot.llm-gateway.tokenStatisticsEnabled",
          "icon": "$(symbol-keyword)",
          "contextualTitle": "%view.tokenUsage.contextualTitle%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "llmGateway.tokenUsage",
        "contents": "%view.tokenUsage.welcome%"
      }
    ],
    "configuration": {
      "title": "GitHub Copilot LLM Gateway",
      "properties": {
        "github.copilot.llm-gateway.serverUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "%config.serverUrl.description%",
          "markdownDescription": "%config.serverUrl.markdownDescription%",
          "order": 1
        },
        "github.copilot.llm-gateway.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.apiKey.description%",
          "markdownDescription": "%config.apiKey.markdownDescription%",
          "order": 2
        },
        "github.copilot.llm-gateway.requestTimeout": {
          "type": "number",
          "default": 60000,
          "description": "%config.requestTimeout.description%",
          "markdownDescription": "%config.requestTimeout.markdownDescription%",
          "order": 3
        },
        "github.copilot.llm-gateway.defaultMaxTokens": {
          "type": "number",
          "default": 32768,
          "description": "%config.defaultMaxTokens.description%",
          "markdownDescription": "%config.defaultMaxTokens.markdownDescription%",
          "order": 4
        },
        "github.copilot.llm-gateway.defaultMaxOutputTokens": {
          "type": "number",
          "default": 4096,
          "description": "%config.defaultMaxOutputTokens.description%",
          "markdownDescription": "%config.defaultMaxOutputTokens.markdownDescription%",
          "order": 5
        },
        "github.copilot.llm-gateway.enableToolCalling": {
          "type": "boolean",
          "default": true,
          "description": "%config.enableToolCalling.description%",
          "markdownDescription": "%config.enableToolCalling.markdownDescription%",
          "order": 6
        },
        "github.copilot.llm-gateway.parallelToolCalling": {
          "type": "boolean",
          "default": true,
          "description": "%config.parallelToolCalling.description%",
          "markdownDescription": "%config.parallelToolCalling.markdownDescription%",
          "order": 7
        },
        "github.copilot.llm-gateway.agentTemperature": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2,
          "description": "%config.agentTemperature.description%",
          "markdownDescription": "%config.agentTemperature.markdownDescription%",
          "order": 8
        },
        "github.copilot.llm-gateway.providers": {
          "type": [
            "object",
            "null"
          ],
          "default": null,
          "description": "%config.providers.description%",
          "markdownDescription": "%config.providers.markdownDescription%",
          "order": 9
        },
        "github.copilot.llm-gateway.showProviderPrefix": {
          "type": "boolean",
          "default": true,
          "description": "%config.showProviderPrefix.description%",
          "markdownDescription": "%config.showProviderPrefix.markdownDescription%",
          "order": 10
        },
        "github.copilot.llm-gateway.providerNameStyle": {
          "type": "string",
          "enum": [
            "slash",
            "bracket"
          ],
          "default": "slash",
          "description": "%config.providerNameStyle.description%",
          "markdownDescription": "%config.providerNameStyle.markdownDescription%",
          "order": 11
        },
        "github.copilot.llm-gateway.configMode": {
          "type": "string",
          "enum": [
            "config-only",
            "config-priority",
            "api-priority"
          ],
          "default": "config-priority",
          "description": "%config.configMode.description%",
          "markdownDescription": "%config.configMode.markdownDescription%",
          "order": 12
        },
        "github.copilot.llm-gateway.enableDebugLogs": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableDebugLogs.description%",
          "markdownDescription": "%config.enableDebugLogs.markdownDescription%",
          "order": 13
        },
        "github.copilot.llm-gateway.enableTokenDebugLogs": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableTokenDebugLogs.description%",
          "markdownDescription": "%config.enableTokenDebugLogs.markdownDescription%",
          "order": 14
        },
        "github.copilot.llm-gateway.enableMessageDebugLogs": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableMessageDebugLogs.description%",
          "markdownDescription": "%config.enableMessageDebugLogs.markdownDescription%",
          "order": 15
        },
        "github.copilot.llm-gateway.enableTokenStatistics": {
          "type": "boolean",
          "default": true,
          "description": "%config.enableTokenStatistics.description%",
          "markdownDescription": "%config.enableTokenStatistics.markdownDescription%",
          "order": 16
        },
        "github.copilot.llm-gateway.logLevel": {
          "type": "string",
          "enum": ["error", "warning", "info", "debug"],
          "default": "info",
          "description": "%config.logLevel.description%",
          "markdownDescription": "%config.logLevel.markdownDescription%",
          "order": 16
        },
        "github.copilot.llm-gateway.logShowTimestamp": {
          "type": "boolean",
          "default": false,
          "description": "%config.logShowTimestamp.description%",
          "markdownDescription": "%config.logShowTimestamp.markdownDescription%",
          "order": 17
        },
        "github.copilot.llm-gateway.logDetailedToolInfo": {
          "type": "boolean",
          "default": false,
          "description": "%config.logDetailedToolInfo.description%",
          "markdownDescription": "%config.logDetailedToolInfo.markdownDescription%",
          "order": 18
        },
        "github.copilot.llm-gateway.enableCopilotUsageReport": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableCopilotUsageReport.description%",
          "markdownDescription": "%config.enableCopilotUsageReport.markdownDescription%",
          "order": 19
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.106.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21"
  },
  "l10n": "./"
}
